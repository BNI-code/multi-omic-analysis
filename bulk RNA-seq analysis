# ============================================================================
# 07_forward_selection.R
# ============================================================================
# Input:  Expression matrix + Boruta confirmed genes + RF model
# Output: Performance metrics for gene combinations (1 to N)
# ============================================================================

library(randomForest)
library(caret)
library(pROC)
library(dplyr)

expr_file   <- "data/expr_matrix.csv"
meta_file   <- "data/subtype_labels.csv"
boruta_file <- "results/markers/boruta_confirmed_genes.csv"
rf_file     <- "results/markers/rf_model.rds"
output_file <- "results/markers/forward_selection_results.csv"

expr <- read.csv(expr_file, row.names=1)
meta <- read.csv(meta_file)
meta$Subtype <- factor(meta$Subtype)
expr <- expr[, meta$Sample]
expr_t <- t(expr)

confirmed <- read.csv(boruta_file)$Gene
confirmed <- confirmed[confirmed %in% colnames(expr_t)]

# sort by RF importance
rf <- readRDS(rf_file)
imp <- as.data.frame(importance(rf))
imp <- imp[confirmed, , drop=F]
imp <- imp[order(imp$MeanDecreaseGini, decreasing=T), , drop=F]
genes_ordered <- rownames(imp)

results <- data.frame(N_genes=integer(), AUC_mean=numeric(), AUC_min=numeric(),
                      Accuracy=numeric(), Specificity_mean=numeric(),
                      Sensitivity_mean=numeric(), Genes=character(),
                      stringsAsFactors=F)

for(i in 1:length(genes_ordered)) {
  g <- genes_ordered[1:i]
  sub <- expr_t[, g, drop=F]
  mtry <- max(1, min(floor(sqrt(ncol(sub))), ncol(sub)))

  set.seed(42)
  rf_i <- randomForest(x=sub, y=meta$Subtype, ntree=ifelse(i==1, 100, 500),
                       mtry=mtry, importance=F)

  pred_prob <- predict(rf_i, type="prob")
  pred_cls  <- predict(rf_i, type="response")

  cm <- confusionMatrix(pred_cls, meta$Subtype)
  acc <- as.numeric(cm$overall["Accuracy"])

  aucs <- c()
  for(s in levels(meta$Subtype)) {
    y <- ifelse(meta$Subtype==s, 1, 0)
    if(length(unique(y)) < 2) next
    aucs <- c(aucs, as.numeric(roc(y, pred_prob[,s], quiet=T, direction="<")$auc))
  }

  results <- rbind(results, data.frame(
    N_genes=i, AUC_mean=mean(aucs, na.rm=T), AUC_min=min(aucs, na.rm=T),
    Accuracy=acc,
    Specificity_mean=ifelse(nlevels(meta$Subtype)==2, as.numeric(cm$byClass["Specificity"]),
                            mean(as.numeric(cm$byClass[,"Specificity"]), na.rm=T)),
    Sensitivity_mean=ifelse(nlevels(meta$Subtype)==2, as.numeric(cm$byClass["Sensitivity"]),
                            mean(as.numeric(cm$byClass[,"Sensitivity"]), na.rm=T)),
    Genes=paste(g, collapse=";"), stringsAsFactors=F
  ))

  if(i %% 5 == 0) cat(i, "genes done\n")
}

write.csv(results, output_file, row.names=F)


