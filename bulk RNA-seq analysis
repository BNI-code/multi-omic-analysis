dir.create(output_dir, showWarnings=F, recursive=T)

expr <- read.csv(expr_file,  row.names=1)
meta <- read.csv(meta_file)
meta$Subtype <- factor(meta$Subtype)
expr <- expr[, meta$Sample]  # match order

expr_t <- t(expr)  # samples x genes

# --- Random Forest ---
set.seed(42)
rf <- randomForest(x=expr_t, y=meta$Subtype, ntree=1000,
                   mtry=sqrt(ncol(expr_t)), importance=T, proximity=T)

saveRDS(rf, file.path(output_dir, "rf_model.rds"))

# confusion matrix
cm <- confusionMatrix(predict(rf), meta$Subtype)
print(cm)

pdf(file.path(output_dir, "confusion_matrix.pdf"), width=6, height=5)
