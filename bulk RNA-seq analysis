ggplot(cm_df, aes(Reference, Prediction, fill=Freq)) +
  geom_tile(color="white") + geom_text(aes(label=Freq), size=12) +
  scale_fill_gradient(low="#f7fbff", high="#08306b") +
  labs(title="Confusion Matrix") + theme_minimal()
dev.off()

# variable importance
imp <- as.data.frame(importance(rf))
imp$Gene <- rownames(imp)
write.csv(imp[order(imp$MeanDecreaseGini, decreasing=T), ],
          file.path(output_dir, "rf_importance.csv"), row.names=F)

