# ============================================================================
# 01_preprocessing.R
# ============================================================================
# Input:  Gene expression matrix (genes x samples)
# Output: Filtered & normalized matrix + top 1000 variable genes
# ============================================================================

library(limma)

input_file  <- "data/expr_matrix.txt"   # modify before running
output_dir  <- "results/"

rt <- read.table(input_file, sep="	", header=T, check.names=F, row.names=1)
expr <- as.matrix(rt)

# filter low-expression genes (keep top 80%)
keep <- rowMeans(expr) > quantile(rowMeans(expr), 0.2)
expr_f <- expr[keep, ]

# normalize
expr_norm <- normalizeBetweenArrays(expr_f)

# top 1000 variable genes by MAD
mads <- apply(expr_norm, 1, mad)
expr_top <- expr_norm[rev(order(mads))[1:1000], ]

dir.create(output_dir, showWarnings=F, recursive=T)
write.table(expr_norm, file=file.path(output_dir, "expr_normalized.txt"), sep="	", quote=F, col.names=NA)
write.table(expr_top,  file=file.path(output_dir, "top1000_genes.txt"),    sep="	", quote=F, col.names=NA)


# ============================================================================
# 02_clustering.R
# ============================================================================
# Input:  Normalized expression matrix
# Output: Clustering results + heatmaps + NMF/ConsensusClusterPlus outputs
# ============================================================================

library(limma)
library(pheatmap)
library(factoextra)
library(cluster)
library(NMF)
library(ConsensusClusterPlus)

input_file  <- "results/expr_normalized.txt"
output_dir  <- "results/clustering/"

dir.create(output_dir, showWarnings=F, recursive=T)

expr <- read.table(input_file, sep="	", header=T, row.names=1, check.names=F)
expr_z <- t(scale(t(expr)))  # z-score by gene

# --- Hierarchical Clustering ---
sample_dist <- dist(t(expr_z), method="euclidean")
hc <- hclust(sample_dist, method="ward.D2")
pdf(file.path(output_dir, "hclust_dendrogram.pdf"))
plot(hc, hang=-1, cex=0.6, main="Sample Hierarchical Clustering")
rect.hclust(hc, k=3, border="red")
dev.off()

# heatmap of top 1000 variable genes
top_var <- order(apply(expr_z, 1, var), decreasing=T)[1:1000]
pdf(file.path(output_dir, "heatmap_top1000.pdf"), width=12, height=10)
pheatmap(expr_z[top_var, ], clustering_method="ward.D2", show_rownames=F,
         color=colorRampPalette(c("blue","white","red"))(100), scale="row")
dev.off()

# --- K-means ---
wss <- sapply(1:10, function(k) kmeans(expr_z, centers=k, nstart=10)$tot.withinss)
pdf(file.path(output_dir, "kmeans_elbow.pdf"))
plot(1:10, wss, type="b", pch=19, xlab="k", ylab="WSS", main="Elbow Method")
dev.off()

set.seed(123)
km <- kmeans(expr_z, centers=2, nstart=25)
pdf(file.path(output_dir, "kmeans_pca.pdf"))
print(fviz_cluster(km, data=t(expr_z), palette="jco", ggtheme=theme_minimal()))
dev.off()

# --- NMF ---
expr_nmf <- as.matrix(expr)
est <- nmfEstimateRank(expr_nmf, range=2:8, method="brunet", nrun=10, .options="vP")
pdf(file.path(output_dir, "nmf_estimate_rank.pdf"))
plot(est)
dev.off()

nmf_res <- nmf(expr_nmf, rank=3, nrun=50, seed=123)
pdf(file.path(output_dir, "nmf_consensus.pdf"))
consensusmap(nmf_res)
dev.off()

# --- ConsensusClusterPlus ---
mads <- apply(expr, 1, mad)
d <- expr[rev(order(mads))[1:3000], ]
d <- sweep(d, 1, apply(d, 1, median, na.rm=T))

results <- ConsensusClusterPlus(d, maxK=10, reps=1000, pItem=0.8, pFeature=1,
                                clusterAlg="pam", distance="pearson",
                                title=output_dir, seed=1262118388.71279, plot="pdf")


# ============================================================================
# 03_tsne.R
# ============================================================================
# Input:  Gene expression matrix
# Output: t-SNE 2D coordinates plot
# ============================================================================

library(Rtsne)
library(ggplot2)

input_file  <- "data/expr_matrix.txt"
output_file <- "results/tsne_plot.pdf"

expr <- read.table(input_file, header=T, row.names=1, sep="	", check.names=F)
expr_t <- t(expr)

# filter: mean FPKM >= 1
keep <- apply(expr_t, 2, function(x) mean(x, na.rm=T) >= 1)
expr_t <- expr_t[, keep]
expr_t <- log2(expr_t + 1)
expr_t <- expr_t[complete.cases(expr_t), ]

set.seed(123)
tsne <- Rtsne(expr_t, dims=2, perplexity=10, max_iter=1000)

df <- data.frame(tsne$Y, Sample=rownames(expr_t))
p <- ggplot(df, aes(X1, X2)) + geom_point(size=3, alpha=0.8) +
     labs(title="t-SNE", x="t-SNE 1", y="t-SNE 2") + theme_minimal() +
     theme(plot.title=element_text(hjust=0.5))

ggsave(output_file, p, width=6, height=5, dpi=300)


# ============================================================================
# 04_differential_analysis.R
# ============================================================================
# Input:  Count matrix + sample metadata with subtype labels
# Output: DESeq2 results + volcano plot + heatmap
# ============================================================================

library(DESeq2)
library(EnhancedVolcano)
library(pheatmap)

count_file  <- "data/count_matrix.txt"
meta_file   <- "data/metadata.csv"   # columns: Sample, Subtype
output_dir  <- "results/degs/"

dir.create(output_dir, showWarnings=F, recursive=T)

counts <- read.table(count_file, sep="	", header=T, row.names=1, check.names=F)
meta   <- read.csv(meta_file)
meta$Subtype <- factor(meta$Subtype)

dds <- DESeqDataSetFromMatrix(countData=counts, colData=meta, design=~ Subtype)
dds <- DESeq(dds)
res <- results(dds, contrast=c("Subtype", "Treat", "Control"))

# significant DEGs
sig <- subset(res, pvalue < 0.05 & abs(log2FoldChange) > 1)

write.csv(as.data.frame(res), file.path(output_dir, "DESeq2_all_results.csv"))
write.csv(as.data.frame(sig),  file.path(output_dir, "DESeq2_sig_genes.csv"))

# volcano plot
pdf(file.path(output_dir, "volcano.pdf"), width=8, height=7)
EnhancedVolcano(res, lab=rownames(res), x="log2FoldChange", y="pvalue",
                pCutoff=0.05, FCcutoff=1, title="Treat vs Control")
dev.off()

# heatmap top DEGs
top500 <- rownames(sig)[1:min(500, nrow(sig))]
pdf(file.path(output_dir, "heatmap_topDEGs.pdf"), width=10, height=12)
pheatmap(counts[top500, ], scale="row", clustering_distance_rows="correlation",
         color=colorRampPalette(c("blue","white","red"))(50), show_rownames=F)
dev.off()


