# ============================================================================
# 09_silhouette_analysis.R
# ============================================================================
# Input:  Expression matrices (3 cohorts) + subtype labels
# Output: Silhouette plots + summary statistics
# ============================================================================

library(cluster)
library(ggplot2)
library(dplyr)
library(gridExtra)

run_silhouette <- function(expr_file, label_file, cohort_name, need_log2=TRUE, sep_expr="	") {
  expr <- read.table(expr_file, header=T, row.names=1, sep=sep_expr, check.names=F, stringsAsFactors=F)
  labels <- read.csv(label_file, stringsAsFactors=F)
  colnames(labels) <- c("SampleID","Subtype")

  common <- intersect(colnames(expr), labels$SampleID)
  expr <- expr[, common, drop=F]
  labels <- labels[match(common, labels$SampleID), ]

  if(need_log2) expr <- log2(expr + 1)
  expr_t <- as.data.frame(t(expr))

  labels$Subtype <- toupper(trimws(as.character(labels$Subtype)))
  labels$SubtypeNum <- as.numeric(factor(labels$Subtype, levels=c("A","B")))

  dist_mat <- dist(expr_t, method="euclidean")
  sil <- silhouette(labels$SubtypeNum, dist=dist_mat)

  sil_df <- data.frame(SampleID=common, Subtype=labels$Subtype,
                       Cluster=sil[,1], Neighbor=sil[,2], Silhouette=sil[,3],
                       Cohort=cohort_name, stringsAsFactors=F)

  summary <- sil_df %>% group_by(Subtype) %>%
    summarise(Mean_Sil=mean(Silhouette), Median_Sil=median(Silhouette),
              Min_Sil=min(Silhouette), Max_Sil=max(Silhouette), N=n(), .groups="drop") %>%
    mutate(Cohort=cohort_name)

  return(list(sil_df=sil_df, summary=summary, overall_mean=mean(sil_df$Silhouette)))
}

# run 3 cohorts
train <- run_silhouette("data/train_30genes.txt",   "data/train_labels.csv",   "Training",     need_log2=T)
val1  <- run_silhouette("data/val1_30genes.txt",    "data/val1_labels.csv",    "Validation1",  need_log2=T)
val2  <- run_silhouette("data/val2_30genes.txt",    "data/val2_labels.csv",    "Validation2",  need_log2=F)

all_sil <- bind_rows(train$sil_df, val1$sil_df, val2$sil_df)
all_sum <- bind_rows(train$summary, val1$summary, val2$summary)

write.csv(all_sil, "results/silhouette_all_samples.csv", row.names=F)
write.csv(all_sum, "results/silhouette_summary.csv", row.names=F)

# plotting function
plot_sil <- function(sil_df, cohort, overall) {
  sil_df <- sil_df %>% arrange(Subtype, Silhouette) %>% mutate(Y_pos=1:n())
  counts <- sil_df %>% count(Subtype)
  gap <- 15
  sil_df$Y_plot <- ifelse(sil_df$Subtype=="A", sil_df$Y_pos, sil_df$Y_pos + gap)
  max_y <- max(sil_df$Y_plot) + 10

  p <- ggplot(sil_df, aes(Silhouette, Y_plot, fill=Subtype)) +
    geom_bar(stat="identity", width=1, alpha=0.8) +
    scale_fill_manual(values=c("A"="#2E86AB","B"="#A23B72")) +
    geom_vline(xintercept=overall, color="#D62828", linetype="dashed", linewidth=1) +
    annotate("text", x=overall+0.05, y=max_y*0.95, label=paste0("Avg=",round(overall,3)),
             color="#D62828", fontface="bold", size=3.5, hjust=0) +
    labs(title=paste0(cohort, "\n(n=",nrow(sil_df),", 30-gene)"),
         x="Silhouette Coefficient", y="Sample Index") +
    xlim(-0.4, 1) + ylim(0, max_y) + theme_minimal() +
    theme(panel.grid.major.y=element_blank(), panel.grid.minor=element_blank(),
          axis.text.y=element_blank(), axis.ticks.y=element_blank(),
          plot.title=element_text(hjust=0.5, face="bold", size=11), legend.position="none")

  y_a <- counts$n[1]/2
  y_b <- counts$n[1] + gap + counts$n[2]/2
  p + annotate("text", x=-0.35, y=y_a, label="Subtype A", fontface="bold", size=4, hjust=0) +
      annotate("text", x=-0.35, y=y_b, label="Subtype B", fontface="bold", size=4, hjust=0)
}

p1 <- plot_sil(train$sil_df, "Training Set", train$overall_mean)
p2 <- plot_sil(val1$sil_df,  "Validation Set 1", val1$overall_mean)
p3 <- plot_sil(val2$sil_df,  "Validation Set 2 (GEO)", val2$overall_mean)

combined <- grid.arrange(p1, p2, p3, ncol=3,
  top=textGrob("Silhouette Analysis of 30-gene Signature", gp=gpar(fontsize=14, fontface="bold")))

ggsave("results/silhouette_three_cohorts.pdf", combined, width=16, height=8, dpi=300)
